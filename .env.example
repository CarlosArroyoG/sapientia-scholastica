# Variables de entorno requeridas
# Copia este archivo como .env.local y rellena los valores

# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/sapientia_db"

# NextAuth — genera un secreto con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI (opcional — si no se configura, usa el resumidor heurístico local)
OPENAI_API_KEY=""

# Seed del admin inicial (usado por npm run db:seed)
SEED_ADMIN_EMAIL="admin@sapientia.edu"
SEED_ADMIN_PASSWORD="cambia-esta-clave"
